# Salin ke deploy/.env.production — JANGAN commit file asli

# Domain publik HTTPS (tanpa slash di akhir)
WARGIO_PUBLIC_URL=https://wargio.contohdomain.com

# Atlas
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=wargio_demo

# API
MCP_LIVE_ENABLED=false
RATE_LIMIT_PER_MINUTE=30
CORS_ORIGINS=https://wargio.contohdomain.com

# Gemini (opsional)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# AGENT_ENGINE_ID=

# Frontend build — kosong = same-origin /api lewat Nginx
NEXT_PUBLIC_API_URL=
