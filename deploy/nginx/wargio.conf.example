# /etc/nginx/sites-available/wargio
# Ganti wargio.contohdomain.com dengan domain Anda

upstream wargio_web {
    # Port host Docker web (lihat deploy/docker/docker-compose.yml)
    server 127.0.0.1:3010;
}

upstream wargio_api {
    server 127.0.0.1:8000;
}

server {
    listen 80;
    server_name wargio.contohdomain.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name wargio.contohdomain.com;

    # Certbot akan mengisi path SSL
    ssl_certificate     /etc/letsencrypt/live/wargio.contohdomain.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/wargio.contohdomain.com/privkey.pem;

    client_max_body_size 2m;

    location /api/ {
        proxy_pass http://wargio_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }

    location / {
        proxy_pass http://wargio_web;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
