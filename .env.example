# MongoDB Atlas — salin ke .env, jangan commit .env
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=wargio_demo

# API (opsional)
API_HOST=0.0.0.0
API_PORT=8000
# Rate limit per session (req/menit)
RATE_LIMIT_PER_MINUTE=30
# CORS frontend (Hari 4) — koma-terpisah
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend (salin ke frontend/.env.local)
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Google Cloud / Agent (Hari 2+)
# GOOGLE_GENAI_USE_VERTEXAI=1
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# AGENT_ENGINE_ID=  # dari output: adk deploy agent_engine

# MCP live stdio — lambat untuk UI; false = pymongo_equivalent (disarankan dev/demo)
MCP_LIVE_ENABLED=false

# URL publik (opsional — gate production Hari 4/5)
# WARGIO_PUBLIC_URL=https://wargio.contohdomain.com
# WARGIO_PRODUCTION_URL=https://wargio.contohdomain.com
