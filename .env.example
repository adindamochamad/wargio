# MongoDB Atlas — salin ke .env, jangan commit .env
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=wargio_demo

# API (opsional)
API_HOST=0.0.0.0
API_PORT=8000
# Rate limit per session (req/menit)
RATE_LIMIT_PER_MINUTE=30

# Google Cloud / Agent (Hari 2+)
# GOOGLE_GENAI_USE_VERTEXAI=1
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# AGENT_ENGINE_ID=  # dari output: adk deploy agent_engine

# MCP live stdio ke mongodb-mcp-server (pool di startup FastAPI)
# MCP_LIVE_ENABLED=true
